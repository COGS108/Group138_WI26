    "df = pd.read_csv('data/02-processed/movies_combined_cleaned.csv')\n",
    "\n",
    "all_actors = df[['Star1','Star2','Star3','Star4']].stack()\n",
    "actor_freqs = all_actors.value_counts()\n",
    "\n",
    "all_actors = df[['Star1', 'Star2', 'Star3', 'Star4']].stack()\n",
    "\n",
    "\n",
    "\n",
    "actors = set(df['Star1']) | set(df['Star2']) | set(df['Star3']) | set(df['Star4'])\n",
    "freqs = {}\n",
    "star1_val_counts = df['Star1'].value_counts(normalize=True)\n",
    "star2_val_counts = df['Star2'].value_counts(normalize=True)\n",
    "star3_val_counts = df['Star3'].value_counts(normalize=True)\n",
    "star4_val_counts = df['Star4'].value_counts(normalize=True)\n",
    "\n",
    "for actor in actors:\n",
    "  actor_col = f'{actor}_Freq'\n",
    "  \n",
    "  freqs[actor_col] = (star1_val_counts.get(actor, 0) + star2_val_counts.get(actor, 0) + star3_val_counts.get(actor, 0) + star4_val_counts.get(actor, 0))\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "def get_star_cast_strength(row):\n",
    "  star1_name = f'{row['Star1']}_Freq'\n",
    "  star2_name = f'{row['Star2']}_Freq'\n",
    "  star3_name = f'{row['Star3']}_Freq'\n",
    "  star4_name = f'{row['Star4']}_Freq'\n",
    "  strength = freqs[star1_name] + freqs[star2_name] + freqs[star3_name] + freqs[star4_name]\n",
    "  return strength\n",
    "\n",
    "df['Star_Cast_Strength'] = df.apply(get_star_cast_strength, axis=1)\n",
    "df.head()\n",
    "\n",
